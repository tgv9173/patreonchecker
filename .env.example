# Required on Render (Dashboard → Environment). For local testing, copy to `.env` and load with your shell or a tool — never commit `.env`.

CLIENT_ID=
CLIENT_SECRET=
ALLOWED_TIER_IDS=
SUCCESS_REDIRECT_URI=

# Must match Patreon OAuth app redirect URIs exactly (often https://YOUR-SERVICE.onrender.com/callback).
REDIRECT_URI=

# Optional overrides (see index.js).
# PROFILE_IMAGE_URL=
# PATREON_PROFILE_URL=
# PIXIV_URL=
