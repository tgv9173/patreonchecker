# Required on Render (Dashboard → Environment). For local testing, copy to `.env` and load with your shell or a tool — never commit `.env`.

CLIENT_ID=
CLIENT_SECRET=
ALLOWED_TIER_IDS=
SUCCESS_REDIRECT_URI=

# Must match Patreon OAuth app redirect URIs exactly (often https://YOUR-SERVICE.onrender.com/callback).
REDIRECT_URI=

# Optional overrides (see index.js).
# PROFILE_IMAGE_URL=
# PATREON_PROFILE_URL=
# PIXIV_URL=
# PATREON_CAMPAIGN_ID=12345678
# PATREON_HTTP_TIMEOUT_MS=45000
# DEVIANTART_URL=https://www.deviantart.com/YOURUSERNAME
# PATREON_API_USER_AGENT=TGV9173-patreon-checker/1.0 (+https://YOUR-SERVICE.onrender.com)

# Usage metrics: search "[analytics]" in Render logs. Optional: POST each event as JSON to a URL
# (Zapier, Make, Airtable automation, your own endpoint).
# ANALYTICS_WEBHOOK_URL=
# Set to "true" to log a "page_home" event on every visit to / (adds noise; off by default).
# ANALYTICS_TRACK_HOME=

# Commission tracking (/commissions) — reads and writes the commission-tracker Google Sheet live
# (patrons can edit their own not-started/preview-sent rows and attach a reference image).
# The sheet ID is the long id in its URL: https://docs.google.com/spreadsheets/d/<THIS PART>/edit
COMMISSION_SHEET_ID=
# Paste the full service-account JSON key as one line. The sheet must be shared with this
# service account's email as EDITOR (not just Viewer) so the app can write edits back.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
